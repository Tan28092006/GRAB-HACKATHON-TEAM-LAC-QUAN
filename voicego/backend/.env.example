# Copy to .env and fill in your own keys (.env is gitignored — never commit it).
FPT_API_KEY=your_fpt_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: enables real web-search grounding for geocoding (else Groq + Nominatim).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
